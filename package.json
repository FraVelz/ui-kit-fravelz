{
  "name": "@fravelz/ui-kit-fravelz",
  "version": "1.2.0",
  "description": "Biblioteca de componentes React personalizados (atoms, molecules, organisms) para sitios de notas y proyectos del portfolio de Fravelz.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "readme.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build:playground": "vite build",
    "vercel-build": "npm run build:playground",
    "build": "tsc -p tsconfig.build.json && cp src/molecules/code-block.css dist/molecules/",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.playground.json",
    "prepublishOnly": "npm run build",
    "lint": "eslint src playground",
    "lint:fix": "eslint src playground --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"playground/**/*.{ts,tsx}\" \"*.{json,md}\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"playground/**/*.{ts,tsx}\" \"*.{json,md}\" \".github/**/*.yml\"",
    "lint:md": "markdownlint-cli2",
    "validate": "npm run lint && npm run format:check && npm run typecheck && npm run lint:md && npm run build",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.11",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.6.2",
    "prismjs": "^1.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "tailwindcss": "^4.1.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.3.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FraVelz/ui-kit-fravelz.git"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "tailwind",
    "fravelz"
  ],
  "author": "Fravelz",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/FraVelz/ui-kit-fravelz/issues"
  },
  "homepage": "https://github.com/FraVelz/ui-kit-fravelz#readme"
}
