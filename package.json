{
  "name": "@fravelz/ui-kit-fravelz",
  "version": "1.1.3",
  "description": "Biblioteca de componentes React personalizados (atoms, molecules, organisms) para sitios de notas y proyectos del portfolio de Fravelz.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "sideEffects": false,
  "files": [
    "dist",
    "readme.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build:playground": "vite build",
    "vercel-build": "npm run build:playground",
    "build": "babel src --out-dir dist --extensions \".js,.jsx\"",
    "prepublishOnly": "npm run build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"*.{json,md}\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx}\" \"*.{json,md}\" \".github/**/*.yml\"",
    "lint:md": "markdownlint-cli2",
    "validate": "npm run lint && npm run format:check && npm run lint:md && npm run build",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@vitejs/plugin-react": "^4.7.0",
    "@eslint/js": "^9.39.1",
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.6.2",
    "prismjs": "^1.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "tailwindcss": "^4.1.11",
    "vite": "^6.3.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FraVelz/ui-kit-fravelz.git"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "tailwind",
    "fravelz"
  ],
  "author": "Fravelz",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/FraVelz/ui-kit-fravelz/issues"
  },
  "homepage": "https://github.com/FraVelz/ui-kit-fravelz#readme"
}
